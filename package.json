{
  "name": "wickrio-compliance-bot",
  "version": "6.60.1",
  "description": "WickrIO Compliance Bot",
  "main": "compliance_bot.js",
  "author": "Paul Cushman",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^8.2.0",
    "fs": "0.0.2",
    "log4js": "^6.6.1",
    "prompt": "^1.0.0",
    "wickrio-bot-api": "7.1.x"
  },
  "scripts": {
    "start": "nohup wpm2 start --no-metrics ./wpm.json >>wpm2.output 2>&1 & echo $! > $(cat pidLocation.json)",
    "stop": "kill $(cat $(cat pidLocation.json))",
    "restart": "kill $(cat $(cat pidLocation.json)) && nohup wpm2 start --no-metrics ./wpm.json >>wpm2.output 2>&1 & echo $! > $(cat pidLocation.json)"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WickrInc/wickrio-compliance-bot"
  },
  "keywords": [
    "wickr",
    "wickrio",
    "wickrbot",
    "bot",
    "bots",
    "secure",
    "messaging",
    "api"
  ],
  "com_wickr": {
    "supports": [
      "cloud",
      "enterprise"
    ]
  }
}
